# Prettier ignore — keep in sync with .gitignore for generated paths.
# Anything listed here is never checked or rewritten by `prettier`.

# Generated lockfile
pnpm-lock.yaml

# Parser test fixtures — these are TEST INPUTS, not source.
# Some are intentionally malformed/truncated (e.g. malformed-truncated-html),
# so reformatting them would change what the Rust parser is tested against.
crates/**/fixtures/**
packages/contracts/fixtures/**

# Cross-language parity goldens — `VOYALIER_REGENERATE_GOLDEN=1` rewrites these
# with serde_json's formatting, so prettier and the regenerator would fight.
packages/contracts/parity/**

# Build outputs and generated artifacts
**/dist/**
**/target/**
**/gen/**
**/.astro/**
**/coverage/**
**/playwright-report/**
**/test-results/**
node_modules/
