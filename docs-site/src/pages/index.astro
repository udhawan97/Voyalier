---
import '../styles/landing.css'
import FoldedRouteArtifact from '../components/FoldedRouteArtifact.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import iconUrl from '@voyalier/brand/voyalier-app-icon.svg?url'
import markUrl from '@voyalier/brand/voyalier-mark.svg?url'
import markDarkUrl from '@voyalier/brand/voyalier-mark-dark.svg?url'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const principles = [
  ['Local by default', 'The trip lives on your device. Connected help runs only after you ask.'],
  ['Evidence stays attached', 'Candidates keep their source, freshness, and confidence until you decide.'],
  ['Useful without AI', 'Planning, review, readiness, offline packs, and sharing work without a model.'],
]

const productScenes = [
  {
    title: 'Every journey has a place.',
    body: 'Trips stay readable at the surface: status, dates, confirmed facts, and anything still waiting for you.',
    image: 'voyalier-trips.jpg',
    alt: 'Voyalier trip list with active, draft, and archived journeys plus local update and encryption controls.',
  },
  {
    title: 'Nothing becomes fact behind your back.',
    body: 'A suggestion remains a candidate until you compare it with the source and confirm, edit, or dismiss it.',
    image: 'voyalier-evidence-review.jpg',
    alt: 'Voyalier evidence review dialog comparing a suggested flight with a quoted source excerpt before confirm, edit, or dismissal.',
  },
  {
    title: 'Travel day stays quiet.',
    body: 'Today brings the next useful detail forward while the Blueprint, checks, and evidence stay within reach.',
    image: 'voyalier-trip-workspace.jpg',
    alt: 'Voyalier trip workspace showing the Kyoto journey, Today summary, pending evidence review, and deterministic Blueprint.',
  },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (() => {
        let storedTheme = ''
        try {
          storedTheme = localStorage.getItem('starlight-theme') || ''
        } catch {
          storedTheme = ''
        }
        const systemTheme = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'
        document.documentElement.dataset.theme =
          storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : systemTheme
      })()
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Voyalier folds scattered plans, confirmations, and sourced travel research into one calm, local-first trip workspace." />
    <meta property="og:title" content="Voyalier — One trip, folded into focus" />
    <meta property="og:description" content="A local-first, evidence-backed trip workspace. Useful without AI. Deeper when invited." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://udhawan97.github.io/Voyalier/" />
    <meta property="og:image" content="https://udhawan97.github.io/Voyalier/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Voyalier — One trip, folded into focus. Local-first, evidence-backed, AI optional." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://udhawan97.github.io/Voyalier/og.png" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <title>Voyalier — One trip, folded into focus</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-nav">
      <a class="wordmark" href={`${base}/`} aria-label="Voyalier home">
        <img class="wordmark-mark wordmark-mark-light" src={markUrl} width="96" height="96" alt="" />
        <img class="wordmark-mark wordmark-mark-dark" src={markDarkUrl} width="96" height="96" alt="" />
        <span>Voyalier</span>
      </a>
      <div class="site-nav__actions">
        <ThemeToggle />
        <a class="nav-download" href={`${base}/download/`}>Download <span aria-hidden="true">↗</span></a>
      </div>
    </header>

    <main id="main-content">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="hero-intro">A local-first trip workspace.</p>
          <h1 id="hero-title">One trip.<br /><span>Folded into focus.</span></h1>
          <p class="hero-lede">Voyalier turns confirmations, research, readiness, and the inevitable “where did I put that?” into one calm, evidence-backed journey.</p>
          <div class="hero-actions">
            <a class="button button-primary" href={`${base}/download/`}>Download Voyalier <span aria-hidden="true">↗</span></a>
            <a class="text-link" href="#product-story">See how it works <span aria-hidden="true">↓</span></a>
          </div>
        </div>
        <div class="hero-art">
          <FoldedRouteArtifact />
        </div>
        <ul class="hero-principles" aria-label="Product principles">
          <li>Runs locally</li>
          <li>Open source</li>
          <li>AI is optional</li>
        </ul>
      </section>

      <section class="premise" aria-labelledby="premise-title">
        <h2 id="premise-title">The plan should remember the details.<br />You should remember the trip.</h2>
        <div class="premise-copy">
          <p>Travel plans arrive as tabs, inbox threads, PDFs, weather checks, and decisions nobody wrote down. Voyalier gives that pile a shape without pretending uncertain information is settled.</p>
          <a class="text-link" href={`${base}/introduction/`}>Read the product principles <span aria-hidden="true">↗</span></a>
        </div>
        <div class="principle-list">
          {principles.map(([title, body]) => (
            <article>
              <h3>{title}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="product-story" id="product-story" aria-labelledby="product-story-title">
        <div class="feature-stack">
          <div class="feature-stack__sticky">
            <h2 id="product-story-title">The whole trip.<br />Visible in one scan.</h2>
            <p>Move from the list of journeys to the source behind one detail, then back to what matters today. The interface changes context; the trust boundary does not.</p>
            <ul>
              <li>Frame the trip</li>
              <li>Review the evidence</li>
              <li>Travel with less noise</li>
            </ul>
            <a class="button button-inverse" href={`${base}/getting-started/`}>Start from source <span aria-hidden="true">↗</span></a>
          </div>

          <div class="feature-stack__scenes">
            {productScenes.map((scene, index) => (
              <figure class="product-scene" data-product-scene data-active={index === 0 ? 'true' : 'false'}>
                <div class="product-scene__image">
                  <img
                    src={`${base}/assets/screenshots/${scene.image}`}
                    width="1440"
                    height="900"
                    loading="lazy"
                    decoding="async"
                    alt={scene.alt}
                  />
                </div>
                <figcaption>
                  <h3>{scene.title}</h3>
                  <p>{scene.body}</p>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>

      <section class="route-proof" aria-labelledby="route-proof-title">
        <header>
          <h2 id="route-proof-title">One honest route from source to trip.</h2>
          <p>Voyalier separates what arrived, what was suggested, what you approved, and what deterministic rules derived. Connected help remains a side branch, never the critical path.</p>
        </header>
        <figure class="diagram diagram-route">
          <img src={`${base}/assets/voyalier-trip-workspace-flow.svg`} width="1440" height="1040" loading="lazy" decoding="async" alt="Six-stage Voyalier workflow: frame the trip, review evidence, pressure-test readiness, prepare offline, travel with Today, and share a redacted brief. Optional AI remains a consent-gated side branch." />
          <figcaption>Six human-sized stages. One trip that still works when the signal disappears.</figcaption>
        </figure>
      </section>

      <section class="trust-proof" aria-labelledby="trust-proof-title">
        <div class="trust-proof__copy">
          <h2 id="trust-proof-title">A source can suggest.<br />Only you can decide.</h2>
          <p>Imported documents and retrieved pages are treated as untrusted. Every candidate keeps its evidence until you review it; every live fact keeps its fetched time and origin.</p>
          <a class="text-link text-link-light" href={`${base}/privacy/`}>Inspect the trust model <span aria-hidden="true">↗</span></a>
        </div>
        <figure class="diagram diagram-evidence">
          <img src={`${base}/assets/voyalier-evidence-pipeline.svg`} width="1440" height="1020" loading="lazy" decoding="async" alt="Voyalier evidence pipeline showing untrusted inputs becoming candidate facts, human review, confirmed trip facts, deterministic planning, and optional consent-gated connected advice." />
          <figcaption>Suggestions stay separate from facts. Model replies stay separate from both.</figcaption>
        </figure>
      </section>

      <section class="architecture" aria-labelledby="architecture-title">
        <header>
          <h2 id="architecture-title">Two runtimes.<br />One local core.</h2>
          <p>The browser development path and native desktop path enter the same application services. Transport changes; product rules do not quietly migrate into UI code—or the cloud.</p>
          <div class="architecture-links">
            <a class="text-link" href={`${base}/architecture/`}>Read the architecture <span aria-hidden="true">↗</span></a>
            <a class="text-link" href="https://github.com/udhawan97/Voyalier">Browse the source <span aria-hidden="true">↗</span></a>
          </div>
        </header>
        <figure class="diagram diagram-architecture">
          <img src={`${base}/assets/voyalier-system-architecture.svg`} width="1440" height="950" loading="lazy" decoding="async" alt="Voyalier system architecture showing the shared workspace, guarded browser development path, direct desktop IPC path, shared application services, deterministic core, local state, and explicit connected sources." />
        </figure>
      </section>

      <section class="closing" aria-labelledby="closing-title" data-closing>
        <div class="closing-mark" aria-hidden="true">
          <FoldedRouteArtifact compact />
          <img src={iconUrl} width="512" height="512" alt="" />
        </div>
        <div class="closing-copy">
          <h2 id="closing-title">Take the trip with you.</h2>
          <p>Open source. Local first. Useful before the network, the model, or the next browser tab enters the picture.</p>
          <div class="closing-actions">
            <a class="button button-primary" href={`${base}/download/`}>Choose your download <span aria-hidden="true">↗</span></a>
            <a class="text-link" href={`${base}/getting-started/`}>Run it from source <span aria-hidden="true">↗</span></a>
          </div>
        </div>
      </section>
    </main>

    <footer class="statement-footer">
      <p class="statement-footer__line">The plan stays useful when the signal disappears.</p>
      <div class="statement-footer__meta">
        <a class="wordmark wordmark-dark" href={`${base}/`} aria-label="Voyalier home">
          <img class="wordmark-mark" src={markDarkUrl} width="96" height="96" alt="" />
          <span>Voyalier</span>
        </a>
        <nav aria-label="Footer navigation">
          <a href={`${base}/privacy/`}>Privacy</a>
          <a href={`${base}/roadmap/`}>Roadmap</a>
          <a href="https://github.com/udhawan97/Voyalier">GitHub</a>
        </nav>
      </div>
    </footer>

    <script>
      document.documentElement.dataset.motionEnhanced = ''

      const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)')
      const finePointer = matchMedia('(hover: hover) and (pointer: fine)')
      const wideLayout = matchMedia('(min-width: 60rem)')
      const artifact = document.querySelector<HTMLElement>('[data-route-artifact]')

      if (artifact) {
        let frame = 0
        const resetArtifactPosition = () => {
          cancelAnimationFrame(frame)
          artifact.style.removeProperty('--artifact-rotate-y')
          artifact.style.removeProperty('--artifact-rotate-x')
        }
        const setArtifactPosition = (event: PointerEvent) => {
          if (!finePointer.matches || reducedMotion.matches || !wideLayout.matches) {
            resetArtifactPosition()
            return
          }
          cancelAnimationFrame(frame)
          frame = requestAnimationFrame(() => {
            const bounds = artifact.getBoundingClientRect()
            const x = (event.clientX - bounds.left) / bounds.width - 0.5
            const y = (event.clientY - bounds.top) / bounds.height - 0.5
            artifact.style.setProperty('--artifact-rotate-y', `${x * 7}deg`)
            artifact.style.setProperty('--artifact-rotate-x', `${y * -5}deg`)
          })
        }
        artifact.addEventListener('pointermove', setArtifactPosition)
        artifact.addEventListener('pointerleave', resetArtifactPosition)
        reducedMotion.addEventListener('change', resetArtifactPosition)
        wideLayout.addEventListener('change', resetArtifactPosition)
      }

      const scenes = Array.from(document.querySelectorAll<HTMLElement>('[data-product-scene]'))
      if ('IntersectionObserver' in window && !reducedMotion.matches && matchMedia('(min-width: 60rem)').matches) {
        const sceneObserver = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0]
            if (!visible) return
            scenes.forEach((scene) => { scene.dataset.active = String(scene === visible.target) })
          },
          { rootMargin: '-18% 0px -18%', threshold: [0.35, 0.55, 0.75] },
        )
        scenes.forEach((scene) => sceneObserver.observe(scene))
      } else {
        scenes.forEach((scene) => { scene.dataset.active = 'true' })
      }

      const closing = document.querySelector<HTMLElement>('[data-closing]')
      if (closing && 'IntersectionObserver' in window && !reducedMotion.matches) {
        const closingObserver = new IntersectionObserver(
          ([entry], observer) => {
            if (!entry?.isIntersecting) return
            closing.classList.add('is-resolved')
            observer.disconnect()
          },
          { threshold: 0.45 },
        )
        closingObserver.observe(closing)
      } else {
        closing?.classList.add('is-resolved')
      }
    </script>
  </body>
</html>
