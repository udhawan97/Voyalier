---
import '../styles/landing.css'
import iconUrl from '@voyalier/brand/voyalier-app-icon.svg?url'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const promises = [
  ['Local by default', 'The trip lives on your device. A network request happens only after you ask for one.'],
  ['Evidence, not vibes', 'Every candidate keeps its source, freshness, and confidence until you confirm it.'],
  ['Useful without AI', 'Rules, review, readiness, offline packs, and sharing work without a model or paid key.'],
]

const capabilities = [
  ['Plan', 'A deterministic Blueprint turns dates and places into a useful starting route.'],
  ['Import', 'Paste, pick, or drop confirmation text, HTML, email, and .eml files.'],
  ['Review', 'Confirm, fix, dismiss, or send a fact back to review—with its source still attached.'],
  ['Check', 'See schedule conflicts, lodging gaps, and honest readiness without false clearance.'],
  ['Prepare', 'Save dated advice, weather, open-data city packs, recommendations, and maps deliberately.'],
  ['Travel', 'Use local search and Today for a quiet now-and-next view when the signal disappears.'],
  ['Protect', 'Seal sensitive evidence with the OS keychain and an optional local passphrase.'],
  ['Assist', 'Invite Ollama, OpenAI, or Anthropic only after an exact redacted-payload preview.'],
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Voyalier folds scattered plans, confirmations, and sourced travel research into one calm, local-first trip workspace." />
    <meta name="theme-color" content="#f3efe4" />
    <meta property="og:title" content="Voyalier — One trip, folded into focus" />
    <meta property="og:description" content="A local-first, evidence-backed trip workspace. Useful without AI. Deeper when invited." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://udhawan97.github.io/Voyalier/" />
    <meta property="og:image" content="https://udhawan97.github.io/Voyalier/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Voyalier — One trip, folded into focus. Local-first, evidence-backed, AI optional." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://udhawan97.github.io/Voyalier/og.png" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <title>Voyalier — One trip, folded into focus</title>
  </head>
  <body>
    <div class="progress" aria-hidden="true"><span></span></div>

    <header class="nav-shell">
      <nav class="nav" aria-label="Primary navigation">
        <a class="brand" href={`${base}/`} aria-label="Voyalier home">
          <svg viewBox="0 0 96 96" aria-hidden="true"><polygon class="ink" points="22,18 38,18 58,80 42,80"></polygon><polygon class="fold" points="42,80 58,80 73.5,32 57.5,32"></polygon><circle class="dot" cx="69" cy="21" r="5"></circle></svg>
          <span>Voyalier</span>
        </a>
        <div class="nav-links">
          <a href="#product">Product</a>
          <a href="#journey">Journey</a>
          <a href="#trust">Trust</a>
          <a href="#architecture">Architecture</a>
          <a href="https://github.com/udhawan97/Voyalier">GitHub</a>
          <a class="nav-cta" href={`${base}/introduction/`}>Read the docs</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="hero snap" aria-labelledby="hero-title">
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="hero-inner">
          <p class="eyebrow hero-kicker">The local-first trip workspace</p>
          <h1 id="hero-title">One trip.<br /><em>Folded into focus.</em></h1>
          <p class="hero-lede">Voyalier turns confirmations, research, readiness, and the inevitable “where did I put that?” into one calm, evidence-backed journey.</p>
          <div class="actions">
            <a class="button primary" href={`${base}/download/`}>Download for Mac or Windows <span aria-hidden="true">↗</span></a>
            <a class="button secondary" href={`${base}/getting-started/`}>Start from source</a>
          </div>
          <div class="hero-proof" aria-label="Product principles">
            <span><i></i> Runs locally</span><span><i></i> Open source</span><span><i></i> AI is optional</span>
          </div>
        </div>
        <div class="fold-stage" aria-hidden="true">
          <span class="orbit orbit-one"></span><span class="orbit orbit-two"></span>
          <span class="mark-medallion"></span>
          <svg viewBox="0 0 96 96"><polygon class="ink" points="22,18 38,18 58,80 42,80"></polygon><polygon class="fold" points="42,80 58,80 73.5,32 57.5,32"></polygon><circle class="dot" cx="69" cy="21" r="5"></circle></svg>
        </div>
        <a class="scroll-hint" href="#product"><span>See the product</span><i aria-hidden="true"></i></a>
      </section>

      <section class="promise snap" aria-labelledby="promise-title">
        <div class="section-intro reveal">
          <p class="eyebrow">Less tab archaeology</p>
          <h2 id="promise-title">A trip should feel like a journey.<br />Planning it should too.</h2>
          <p>Voyalier separates what a source suggested from what you actually approved. It remembers the boring details so you can remember the good ones.</p>
        </div>
        <div class="promise-grid">
          {promises.map(([title, body], index) => (
            <article class="principle reveal" style={`--delay:${index}`}>
              <span class="number">0{index + 1}</span><h3>{title}</h3><p>{body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="product snap" id="product" aria-labelledby="product-title">
        <div class="section-intro reveal">
          <p class="eyebrow">The working product</p>
          <h2 id="product-title">The whole trip loop.<br />Visible in one scan.</h2>
          <p>For a traveler, Voyalier is a calmer place to keep the trip. For a developer, every feature below crosses the same versioned contract and keeps its trust boundary explicit.</p>
        </div>
        <div class="capability-grid">
          {capabilities.map(([title, body], index) => (
            <article class="capability reveal" style={`--delay:${index % 4}`}>
              <span>0{index + 1}</span><h3>{title}</h3><p>{body}</p>
            </article>
          ))}
        </div>
        <div class="product-gallery">
          <figure class="product-shot product-shot-wide reveal">
            <div class="frame-bar"><span>Your trips</span><span>Local workspace</span></div>
            <img src={`${base}/assets/screenshots/voyalier-trips.jpg`} width="1440" height="900" loading="lazy" decoding="async" alt="Voyalier trip list with active, draft, and archived journeys plus local update and encryption controls." />
            <figcaption>Trips stay simple at the surface: status, dates, confirmed facts, and anything still waiting for you.</figcaption>
          </figure>
          <figure class="product-shot reveal">
            <div class="frame-bar"><span>Evidence review</span><span>Nothing saved yet</span></div>
            <img src={`${base}/assets/screenshots/voyalier-evidence-review.jpg`} width="1440" height="900" loading="lazy" decoding="async" alt="Voyalier review dialog comparing a suggested flight with a quoted source excerpt before confirm, edit, or dismissal." />
            <figcaption>The important interaction is not extraction. It is the review gate between a suggestion and a fact.</figcaption>
          </figure>
        </div>
      </section>

      <section class="story story-dark snap" id="journey" aria-labelledby="journey-title">
        <div class="story-copy reveal">
          <p class="eyebrow">For travelers · the whole route</p>
          <h2 id="journey-title">From “we should go”<br />to “we are ready.”</h2>
          <p>Frame the trip, review what was found, pressure-test the gaps, prepare offline, travel with Today, then share only what belongs in the brief.</p>
          <ul class="plain-list"><li>Six human-sized steps</li><li>No model in the critical path</li><li>Connected help stays an explicit side branch</li></ul>
        </div>
        <figure class="diagram-frame diagram-dark reveal">
          <div class="frame-bar"><span>Product flow</span><span class="live-dot">Built for real travel</span></div>
          <img src={`${base}/assets/voyalier-trip-workspace-flow.svg`} width="1440" height="1040" loading="lazy" decoding="async" alt="Six-stage Voyalier workflow: frame the trip, review evidence, pressure-test readiness, prepare offline, travel with Today, and share a redacted brief. Optional AI remains a consent-gated side branch." />
          <figcaption><strong>Casual view:</strong> six steps, one calm route. <strong>Developer view:</strong> deterministic rules remain authoritative from input to redacted output.</figcaption>
        </figure>
      </section>

      <section class="story story-light snap" id="trust" aria-labelledby="trust-title">
        <div class="story-copy reveal">
          <p class="eyebrow">For humans · a visible trust boundary</p>
          <h2 id="trust-title">Nothing becomes a fact<br />behind your back.</h2>
          <p>Documents and sources produce candidates—not truth by decree. Voyalier shows the evidence, asks for a decision, and records what changed.</p>
          <div class="trust-legend"><span><i class="local"></i> Local typed flow</span><span><i class="network"></i> Network only after a click</span></div>
        </div>
        <figure class="diagram-frame reveal">
          <div class="frame-bar"><span>Evidence lifecycle</span><span>Candidate → decision → fact</span></div>
          <img src={`${base}/assets/voyalier-evidence-pipeline.svg`} width="1440" height="1020" loading="lazy" decoding="async" alt="Voyalier evidence pipeline showing untrusted inputs becoming candidate facts, human review, confirmed trip facts, deterministic planning, and optional consent-gated connected advice." />
          <figcaption><strong>Plain English:</strong> show your work. <strong>Technical contract:</strong> provenance, freshness, confidence, and license travel with every claim.</figcaption>
        </figure>
      </section>

      <section class="story story-architecture snap" id="architecture" aria-labelledby="architecture-title">
        <div class="story-copy reveal">
          <p class="eyebrow">For builders · one product contract</p>
          <h2 id="architecture-title">Two runtimes.<br />One local core.</h2>
          <p>The browser development path and native desktop path enter the same application services. Product rules do not quietly migrate into UI code—or the cloud.</p>
          <div class="code-pills"><code>React + TypeScript</code><code>Rust + Tauri</code><code>SQLite + keychain</code></div>
        </div>
        <figure class="diagram-frame reveal">
          <div class="frame-bar"><span>System map</span><span>No mystery arrows</span></div>
          <img src={`${base}/assets/voyalier-system-architecture.svg`} width="1440" height="950" loading="lazy" decoding="async" alt="Voyalier system architecture showing the shared workspace, guarded browser development path, direct desktop IPC path, shared application services, deterministic core, local state, and explicit connected sources." />
          <figcaption><strong>Traveler promise:</strong> the same trip everywhere. <strong>Developer promise:</strong> transport changes; product rules do not.</figcaption>
        </figure>
      </section>

      <section class="closing snap" aria-labelledby="close-title">
        <img src={iconUrl} width="512" height="512" alt="Voyalier app icon" class="app-icon reveal" loading="lazy" />
        <p class="eyebrow reveal">Ready when the trip is</p>
        <h2 id="close-title" class="reveal">Plan with evidence.<br /><em>Travel with less noise.</em></h2>
        <p class="reveal">Open source. Local first. Refreshingly uninterested in pretending a chatbot is a border official.</p>
        <div class="actions reveal"><a class="button primary" href={`${base}/introduction/`}>Enter the docs</a><a class="button secondary" href="https://github.com/udhawan97/Voyalier">View the repository</a></div>
      </section>
    </main>

    <footer>
      <a class="brand footer-brand" href={`${base}/`}><svg viewBox="0 0 96 96" aria-hidden="true"><polygon class="ink" points="22,18 38,18 58,80 42,80"></polygon><polygon class="fold" points="42,80 58,80 73.5,32 57.5,32"></polygon><circle class="dot" cx="69" cy="21" r="5"></circle></svg><span>Voyalier</span></a>
      <p>Local-first travel intelligence, folded carefully.</p>
      <div><a href={`${base}/privacy/`}>Privacy</a><a href={`${base}/architecture/`}>Architecture</a><a href={`${base}/roadmap/`}>Roadmap</a><a href="https://github.com/udhawan97/Voyalier">GitHub</a></div>
    </footer>

    <script>
      const root = document.documentElement
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches
      const reveals = document.querySelectorAll('.reveal')
      if (!reduced && 'IntersectionObserver' in window) {
        root.classList.add('motion-ready')
        const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
          if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target) }
        }), { threshold: 0.12, rootMargin: '0px 0px -5% 0px' })
        reveals.forEach((item) => observer.observe(item))
      }

      const progress = document.querySelector<HTMLElement>('.progress span')
      let ticking = false
      const updateProgress = () => {
        const max = root.scrollHeight - root.clientHeight
        if (progress) progress.style.transform = `scaleX(${max > 0 ? root.scrollTop / max : 0})`
        ticking = false
      }
      addEventListener('scroll', () => { if (!ticking) { ticking = true; requestAnimationFrame(updateProgress) } }, { passive: true })
      updateProgress()
    </script>
  </body>
</html>
